{
  "config": {
    "function": {
      "name": "gongjuxiang",
      "runtime": "nodejs16",
      "handler": "server.handler"
    },
    "assets": {
      "directory": "./dist",
      "ignore": [
        "node_modules",
        ".git"
      ]
    },
    "build": {
      "command": "npm install",
      "outputDir": "./"
    },
    "entry": "./dist/app.js"
  }
}
