{
  "config": {
    "function": {
      "name": "gongjuxiang",
      "runtime": "nodejs16",
      "handler": "server.handler"
    },
    "assets": {
      "dir": "./",
      "ignore": [
        "node_modules",
        ".git"
      ]
    },
    "build": {
      "command": "npm install",
      "outputDir": "./"
    }
  }
}